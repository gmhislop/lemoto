    ]
  },
  "dependencies": {
    "@expo-google-fonts/dm-mono": "^0.3.0",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "^55.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-community/slider": "5.1.2",
    "expo": "^55.0.11",
    "expo-constants": "~55.0.11",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-notifications": "~55.0.16",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "jest-expo": "~55.0.13",
    "nativewind": "^4.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-shared-group-preferences": "^1.1.24",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.13",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
